{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofs-sdk.dev/schemas/assetbundle-index.schema.json",
  "title": "OFS AssetBundle Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "unityVersion", "buildTarget", "bundles"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "unityVersion": { "type": "string", "minLength": 1 },
    "buildTarget": { "const": "StandaloneWindows64" },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "bytes", "sha256", "unityHash", "dependencies"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^/\\\\]+$"
          },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
          "unityHash": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
