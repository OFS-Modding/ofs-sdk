{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofs-sdk.dev/schemas/mod-manifest.schema.json",
  "title": "OFS Mod Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "assembly",
    "entryPoint",
    "sdkVersion"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$" },
    "description": { "type": "string", "maxLength": 1000 },
    "author": { "type": "string", "maxLength": 100 },
    "assembly": { "type": "string", "minLength": 5 },
    "entryPoint": { "type": "string", "minLength": 3 },
    "sdkVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "dependencies": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{3,80}$" },
          "version": { "type": "string", "minLength": 1, "maxLength": 100 },
          "optional": { "type": "boolean" }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 100,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._-]{3,80}$" }
    },
    "multiplayer": {
      "enum": ["unknown", "client", "server", "required", "incompatible"]
    }
  }
}
